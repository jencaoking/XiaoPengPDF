<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:XiaoPengPDF.ViewModels"
             mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="400"
             x:Class="XiaoPengPDF.Views.PdfOutlineView"
             x:DataType="vm:PdfOutlineViewModel">

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="12,8">
            <TextBlock Text="大纲" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" Foreground="#1E293B"/>
        </Border>

        <TextBlock Grid.Row="1" Text="无大纲"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="#94A3B8"
                   FontSize="13"
                   IsVisible="{Binding !HasOutline}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" IsVisible="{Binding HasOutline}" Padding="8">
            <TreeView ItemsSource="{Binding OutlineItems}" Background="Transparent">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate x:DataType="vm:OutlineItemViewModel" ItemsSource="{Binding Children}">
                        <Border Padding="6,4" Background="Transparent" CornerRadius="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z" Width="14" Height="14" Foreground="#3B82F6" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontSize="13" Foreground="#1E293B"/>
                                    <TextBlock Text="{Binding PageNumber, StringFormat='第 {0} 页'}"
                                               Foreground="#94A3B8"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </ScrollViewer>
    </Grid>
</UserControl>
