<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="PrimaryBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#8B5CF6"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>

    <SolidColorBrush x:Key="BackgroundBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceVariantBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="TextBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#94A3B8"/>

    <SolidColorBrush x:Key="BorderBrush" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="DividerBrush" Color="#E2E8F0"/>

    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#F8FAFC"/>

    <SolidColorBrush x:Key="PdfViewerBackgroundBrush" Color="#525659"/>
    <SolidColorBrush x:Key="PdfPageBackgroundBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="IconBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="IconHoverBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="IconActiveBrush" Color="#2563EB"/>

    <Thickness x:Key="StandardMargin">12</Thickness>
    <Thickness x:Key="SmallMargin">8</Thickness>
    <Thickness x:Key="LargeMargin">16</Thickness>
    <CornerRadius x:Key="StandardCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="SmallCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="LargeCornerRadius">12</CornerRadius>

    <x:Double x:Key="IconSize">20</x:Double>
    <x:Double x:Key="SmallIconSize">16</x:Double>
    <x:Double x:Key="LargeIconSize">24</x:Double>

    <x:Double x:Key="ToolbarHeight">48</x:Double>
    <x:Double x:Key="SidebarWidth">280</x:Double>
    <x:Double x:Key="StatusBarHeight">32</x:Double>

    <SolidColorBrush x:Key="DarkPrimaryBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="DarkPrimaryHoverBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="DarkBackgroundBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="DarkSurfaceBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="DarkSurfaceVariantBrush" Color="#334155"/>
    <SolidColorBrush x:Key="DarkTextBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="DarkTextSecondaryBrush" Color="#94A3B8"/>
    <SolidColorBrush x:Key="DarkTextTertiaryBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="DarkBorderBrush" Color="#334155"/>
    <SolidColorBrush x:Key="DarkDividerBrush" Color="#334155"/>
    <SolidColorBrush x:Key="DarkSidebarBackgroundBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="DarkToolbarBackgroundBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="DarkStatusBarBackgroundBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="DarkPdfViewerBackgroundBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="DarkIconBrush" Color="#94A3B8"/>
    <SolidColorBrush x:Key="DarkIconHoverBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="DarkIconActiveBrush" Color="#3B82F6"/>
</ResourceDictionary>
